{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "outDir": "./dist",
      "rootDir": "./src",
      "types": ["node"],
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "baseUrl": ".",
      "paths": {
        "@pmtp/shared": ["../../packages/shared/dist/index"]
      }
    },
    "include": ["src/**/*.ts"],
    "exclude": [
      "node_modules",
      "dist",
      "test",
      "src/**/*.spec.ts",
      "src/**/__tests__/**"
    ]
  }