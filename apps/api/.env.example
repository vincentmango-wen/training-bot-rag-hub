# apps/api 用 Prisma CLI / NestJS 起動の環境変数テンプレート（実値は .env のみに記入）。
# DB は docker-compose の postgres（pgvector 同梱 / host port 5433）。
#
# schema=public を使う理由: pgvector 拡張が public に常駐し vector 型・演算子が
# search_path に解決されるため（$queryRaw の ANN 検索で必須）。
# order_permission の一次防御は DB ロール GRANT 物理遮断（schema 非依存 / 05 §2.4.3）。
DATABASE_URL=postgresql://rag_user:rag_password_local_only@localhost:5433/rag_hub?schema=public
DIRECT_URL=postgresql://rag_user:rag_password_local_only@localhost:5433/rag_hub?schema=public

# --- Provider 層（apps/api/src/modules/rag/infrastructure/providers） ---
# OpenAI API キー（13 Secret 送信禁止 / コードに焼かない / ログ出力禁止）。
# 未設定でも DI 解決・テスト（mock 注入）は通る。実呼び出し時にのみ必須。
# 実 SDK 利用には `npm i openai`（apps/api）が別途必要（adapter が遅延 require）。
OPENAI_API_KEY=

