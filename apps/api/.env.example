# apps/api 用 Prisma CLI / NestJS 起動の環境変数テンプレート（実値は .env のみに記入）。
# DB は docker-compose の postgres（pgvector 同梱 / host port 5433）。
#
# schema=public を使う理由: pgvector 拡張が public に常駐し vector 型・演算子が
# search_path に解決されるため（$queryRaw の ANN 検索で必須）。
# order_permission の一次防御は DB ロール GRANT 物理遮断（schema 非依存 / 05 §2.4.3）。
DATABASE_URL=postgresql://rag_user:rag_password_local_only@localhost:5433/rag_hub?schema=public
DIRECT_URL=postgresql://rag_user:rag_password_local_only@localhost:5433/rag_hub?schema=public

# --- Neon 移行後はこちらの形式に差し替える（docs/operations/neon-setup.md 参照） ---
# 実行時用（Pooled / -pooler ホスト）。pgbouncer=true は Prisma + PgBouncer transaction mode に必須。
# connection_limit=1 は Vercel serverless（1 invocation = 1 接続）想定。ローカル開発で Neon に繋ぐ場合は外してよい。
# DATABASE_URL=postgresql://<role>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&pgbouncer=true&connection_limit=1&schema=public
# migration 用（Direct / pooler なしホスト）。prisma migrate deploy はこちらを使う（schema.prisma の directUrl）。
# DIRECT_URL=postgresql://<role>:<password>@<endpoint>.<region>.aws.neon.tech/<db>?sslmode=require&schema=public

# --- Provider 層（apps/api/src/modules/rag/infrastructure/providers） ---
# OpenAI API キー（13 Secret 送信禁止 / コードに焼かない / ログ出力禁止）。
# 未設定でも DI 解決・テスト（mock 注入）は通る。実呼び出し時にのみ必須。
# 実 SDK 利用には `npm i openai`（apps/api）が別途必要（adapter が遅延 require）。
OPENAI_API_KEY=

# --- Phase 3: アプリ側 Bearer Token（非公開化ダブルロックの内側） ---
# 全 HTTP ルートに `Authorization: Bearer <この値>` を強制する（/health も対象）。
# 生成方法: `openssl rand -hex 32`（docs/operations/vercel-deploy.md §環境変数 参照）。
# 未設定 / 空文字 のときは guard が fail-closed（全リクエスト 503）で落ちる。
# 設定は本番（Vercel 環境変数）・ローカル `.env`・呼び出しクライアントの 3 箇所同期。
# ログ出力・コード焼き込み・PR 本文への記入は禁止（Sensitive 扱い）。
API_BEARER_TOKEN=

